# EU Financial Reg Horizon Scanner local environment
#
# Demo mode works without secrets. Leave DATABASE_URL empty to use fixture and
# dry-run paths where supported.

# Persistent mode
DATABASE_URL=

# Authentication
# Configure Clerk for real multi-user review queues. Demo paths must not be used
# for production delivery.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Delivery integrations
# External delivery remains blocked unless reviewer approval and proof-packet
# checks pass. Store real tokens only in local or deployment secrets.
SLACK_BOT_TOKEN=
MS_TEAMS_WEBHOOK_URL=
HUBSPOT_ACCESS_TOKEN=
RESEND_API_KEY=

# Runtime safety
# Production without DATABASE_URL and auth should fail closed.
NODE_ENV=development
