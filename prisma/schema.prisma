// ---------------------------------------------------------------------------
// Agents
// ---------------------------------------------------------------------------

model AgentDefinition {
  id                String       @id
  kind              AgentKind    @unique
  name              String
  description       String       @db.Text
  version           String
  enabled           Boolean      @default(true)
  schedule          String?
  capabilities      String[]     @default([])
  llmPolicy         AgentLlmPolicy @default(NONE)
  maxRuntimeSeconds Int          @default(60)
  maxCostCents      Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  permissions       AgentToolPermission[]
  runs              AgentRun[]
}

model AgentToolPermission {
  id                String       @id @default(cuid())
  agentDefinitionId String
  capability        String
  isEnabled         Boolean      @default(true)
  createdAt         DateTime     @default(now())

  agentDefinition   AgentDefinition @relation(fields: [agentDefinitionId], references: [id], onDelete: Cascade)

  @@unique([agentDefinitionId, capability])
  @@index([capability, isEnabled])
}

model AgentRun {
  id                String       @id @default(cuid())
  agentDefinitionId String?
  kind              AgentKind
  status            AgentRunStatus @default(QUEUED)
  organisationId    String?
  triggeredByUserId String?
  trigger           String
  agentVersion      String
  inputHash         String
  outputHash        String?
  model             String?
  promptVersion     String?
  costCents         Int?
  startedAt         DateTime     @default(now())
  finishedAt        DateTime?
  errorMessage      String?      @db.Text

  definition        AgentDefinition? @relation(fields: [agentDefinitionId], references: [id], onDelete: SetNull)
  steps             AgentRunStep[]
  artifacts         AgentArtifact[]

  @@index([kind, startedAt])
  @@index([organisationId, startedAt])
  @@index([status, startedAt])
}

model AgentRunStep {
  id                String       @id @default(cuid())
  agentRunId        String
  stepKey           String
  status            AgentRunStatus @default(RUNNING)
  inputJson         Json
  outputJson        Json?
  errorMessage      String?      @db.Text
  startedAt         DateTime     @default(now())
  finishedAt        DateTime?

  agentRun          AgentRun     @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, startedAt])
}

model AgentArtifact {
  id                String       @id @default(cuid())
  agentRunId        String
  organisationId    String?
  publicationId     String?
  productMapId      String?
  type              AgentArtifactType
  status            AgentArtifactStatus @default(DRAFT)
  title             String
  summary           String       @db.Text
  payloadJson       Json
  provenanceJson    Json
  createdAt         DateTime     @default(now())
  reviewedAt        DateTime?
  reviewedById      String?

  agentRun          AgentRun     @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([organisationId, status])
  @@index([publicationId, type])
  @@index([type, status])
  @@index([createdAt])
}

enum AgentKind {
  SOURCE_MONITOR
  REVIEW_QA
  BRIEFING
  CLASSIFICATION_TRIAGE
  DIFF_EXPLAINER
  IMPACT_EXPLANATION
  ALERT_DRAFT
  SERVICE_ROUTING
  AUDIT_QA
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  BLOCKED_BY_POLICY
}

enum AgentArtifactType {
  FINDING
  REVIEW_SUGGESTION
  BRIEFING_DRAFT
  ALERT_DRAFT
  SERVICE_RULE_SUGGESTION
  SOURCE_DILIGENCE_NOTE
  IMPACT_EXPLANATION
}

enum AgentArtifactStatus {
  DRAFT
  APPROVED
  DISMISSED
  APPLIED
}

enum AgentLlmPolicy {
  NONE
  PUBLICATION_ONLY
  REDACTED_LOCAL_FACTS
}

model AuditLog {
  id             String       @id @default(cuid())
  actorUserId    String?
  organisationId String?
  action         String
  entityType     String
  entityId       String
  payloadJson    Json?
  createdAt      DateTime     @default(now())

  @@index([entityType, entityId])
  @@index([organisationId, createdAt])
}
